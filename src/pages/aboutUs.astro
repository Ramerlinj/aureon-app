---
import Layout from "../layouts/Layout.astro";

const areas = [
  {
    title: "Analisis",
    subtitle: "Decision estrategica con datos reales",
    description:
      "Leemos tendencias, medimos comportamiento y transformamos informacion en planes accionables para direccion y operaciones.",
    tone: "Investigacion, KPIs y arquitectura de informacion.",
    accent: "#f7b500",
    image:
      "https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?auto=format&fit=crop&w=1600&q=80",
    alt: "Documentos y laptop en escritorio minimalista para analisis",
  },
  {
    title: "Multimedia",
    subtitle: "Historias visuales que capturan atencion",
    description:
      "Produccion creativa para marca, redes y campañas. Combinamos direccion de arte, video y motion para piezas con identidad propia.",
    tone: "Branding visual, fotografia y contenido audiovisual.",
    accent: "#16d1ff",
    image:
      "https://images.unsplash.com/photo-1574717024653-61fd2cf4d44d?auto=format&fit=crop&w=1600&q=80",
    alt: "Equipo de produccion audiovisual en estudio profesional",
  },
  {
    title: "Desarrollo de Software",
    subtitle: "Plataformas solidas para crecer sin friccion",
    description:
      "Construimos productos web y moviles con enfoque en performance, mantenibilidad y escalabilidad para negocio y usuarios finales.",
    tone: "Arquitectura, APIs y desarrollo full stack.",
    accent: "#46d46a",
    image:
      "https://images.unsplash.com/photo-1555066931-4365d14bab8c?auto=format&fit=crop&w=1600&q=80",
    alt: "Monitor con codigo fuente en entorno de desarrollo moderno",
  },
  {
    title: "Redes",
    subtitle: "Infraestructura conectada, segura y estable",
    description:
      "Disenamos topologias robustas y monitoreadas para asegurar continuidad, baja latencia y control en todos los puntos de acceso.",
    tone: "Conectividad corporativa, seguridad y monitoreo.",
    accent: "#6aa8ff",
    image:
      "https://images.unsplash.com/photo-1544197150-b99a580bb7a8?auto=format&fit=crop&w=1600&q=80",
    alt: "Cables de red Ethernet iluminados con tonos azules en datacenter",
  },
  {
    title: "Robotica",
    subtitle: "Automatizacion inteligente para operaciones",
    description:
      "Integramos software, sensores y hardware para soluciones autonomas que aumentan precision, velocidad y eficiencia operativa.",
    tone: "Prototipado, control y sistemas mecatronicos.",
    accent: "#ff5579",
    image:
      "https://images.unsplash.com/photo-1535378620166-273708d44e4c?auto=format&fit=crop&w=1600&q=80",
    alt: "Brazo robotico industrial en linea de produccion automatizada",
  },
];
---

<Layout>
  <main class="about-us-page">
    <section class="about-hero" aria-label="Presentacion About US">
      <div class="hero-noise"></div>
      <div class="hero-content">
        <p class="hero-kicker hero-anim">AUREON // ABOUT US</p>
        <h1 class="hero-title hero-anim">Areas Especializadas, Impacto Real</h1>
        <p class="hero-copy hero-anim">
          Cada equipo domina un frente distinto, pero todos trabajamos con la
          misma obsesion: resultados potentes con ejecucion impecable.
        </p>
      </div>
      <div class="hero-glow"></div>
    </section>

    <section class="cinematic-areas" aria-label="Areas de la empresa">
      {
        areas.map((area, index) => (
          <article
            class={`story-panel ${index % 2 === 0 ? "is-left" : "is-right"}`}
            style={`--accent:${area.accent};`}
          >
            <div class="panel-media">
              <img
                src={area.image}
                alt={area.alt}
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="panel-shade" />
            <div class="panel-content-wrap">
              <div class="panel-content">
                <span class="panel-number">0{index + 1}</span>
                <h2>{area.title}</h2>
                <p class="panel-subtitle">{area.subtitle}</p>
                <p class="panel-description">{area.description}</p>
                <p class="panel-tone">{area.tone}</p>
              </div>
            </div>
          </article>
        ))
      }
    </section>
  </main>
</Layout>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const runAnimations = () => {
    const heroItems = gsap.utils.toArray(".hero-anim");
    const panels = gsap.utils.toArray(".story-panel");

    gsap.fromTo(
      heroItems,
      { y: 50, opacity: 0, filter: "blur(6px)" },
      {
        y: 0,
        opacity: 1,
        filter: "blur(0px)",
        duration: 1.1,
        ease: "power4.out",
        stagger: 0.15,
      },
    );

    panels.forEach((panel, idx) => {
      const media = panel.querySelector(".panel-media img");
      const shade = panel.querySelector(".panel-shade");
      const content = panel.querySelector(".panel-content");

      gsap.fromTo(
        media,
        {
          scale: 1.25,
          yPercent: idx % 2 === 0 ? -6 : 6,
          filter: "brightness(0.56) saturate(0.8)",
        },
        {
          scale: 1,
          yPercent: 0,
          filter: "brightness(0.9) saturate(1)",
          ease: "none",
          scrollTrigger: {
            trigger: panel,
            start: "top bottom",
            end: "bottom top",
            scrub: true,
          },
        },
      );

      gsap.fromTo(
        shade,
        { opacity: 0.82 },
        {
          opacity: 0.46,
          ease: "none",
          scrollTrigger: {
            trigger: panel,
            start: "top 78%",
            end: "bottom 25%",
            scrub: true,
          },
        },
      );

      gsap.fromTo(
        content,
        {
          y: 90,
          opacity: 0,
          clipPath: "inset(0 0 100% 0)",
        },
        {
          y: 0,
          opacity: 1,
          clipPath: "inset(0 0 0% 0)",
          duration: 1.2,
          ease: "power4.out",
          scrollTrigger: {
            trigger: panel,
            start: "top 70%",
            toggleActions: "play none none reverse",
          },
        },
      );
    });

    gsap.to(".hero-glow", {
      yPercent: 35,
      ease: "none",
      scrollTrigger: {
        trigger: ".about-hero",
        start: "top top",
        end: "bottom top",
        scrub: true,
      },
    });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", runAnimations, {
      once: true,
    });
  } else {
    runAnimations();
  }
</script>

<style>
  .about-us-page {
    --bg: #030303;
    --ink: #e8e6e3;
    color: var(--ink);
    background:
      radial-gradient(
        circle at 20% 15%,
        rgba(190, 27, 27, 0.08),
        transparent 50%
      ),
      radial-gradient(
        circle at 80% 10%,
        rgba(190, 27, 27, 0.04),
        transparent 50%
      ),
      linear-gradient(180deg, #030303 0%, #070707 28%, #010101 100%);
    min-height: 100svh;
  }

  .about-hero {
    position: relative;
    min-height: 92svh;
    padding: 8.5rem 1.2rem 4rem;
    overflow: clip;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 72rem;
    margin-inline: auto;
    text-align: center;
  }

  .hero-kicker {
    margin: 0;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.34em;
    font-weight: 700;
    color: rgba(190, 150, 150, 0.6);
  }

  .hero-title {
    margin: 1rem auto 0;
    max-width: 13ch;
    text-transform: uppercase;
    line-height: 0.92;
    text-wrap: balance;
    font-size: clamp(2.2rem, 9vw, 6.2rem);
    letter-spacing: 0.025em;
    color: rgba(242, 247, 255, 0.92);
    text-shadow: 0 0 60px rgba(190, 27, 27, 0.08);
  }

  .hero-copy {
    margin: 1.25rem auto 0;
    max-width: 56ch;
    color: rgba(195, 195, 195, 0.7);
    font-size: clamp(1rem, 2.2vw, 1.22rem);
    line-height: 1.58;
  }

  .hero-noise {
    position: absolute;
    inset: 0;
    opacity: 0.06;
    background-image: radial-gradient(
      rgba(255, 255, 255, 0.25) 0.8px,
      transparent 0.8px
    );
    background-size: 3px 3px;
    pointer-events: none;
  }

  .hero-glow {
    position: absolute;
    z-index: 1;
    left: 50%;
    bottom: -20rem;
    width: min(70rem, 95vw);
    aspect-ratio: 1 / 0.72;
    transform: translateX(-50%);
    background: radial-gradient(
      ellipse at center,
      rgba(190, 27, 27, 0.12),
      rgba(190, 27, 27, 0.03) 55%,
      transparent 72%
    );
    filter: blur(12px);
    pointer-events: none;
  }

  .cinematic-areas {
    padding: 1rem 0 4rem;
    display: grid;
    gap: 1.2rem;
  }

  .story-panel {
    position: relative;
    min-height: min(86vh, 48rem);
    border-block: 1px solid rgba(255, 255, 255, 0.04);
    overflow: clip;
    isolation: isolate;
  }

  .panel-media,
  .panel-media img,
  .panel-shade {
    position: absolute;
    inset: 0;
  }

  .panel-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .panel-shade {
    z-index: 1;
    background: linear-gradient(
      115deg,
      rgba(3, 5, 9, 0.92),
      rgba(3, 5, 9, 0.32) 45%,
      color-mix(in srgb, var(--accent), transparent 82%) 100%
    );
  }

  .panel-content-wrap {
    position: relative;
    z-index: 2;
    min-height: min(86vh, 48rem);
    width: min(75rem, 100%);
    margin-inline: auto;
    display: grid;
    align-items: center;
    padding: 2.1rem 1.2rem;
  }

  .is-right .panel-content-wrap {
    justify-items: end;
  }

  .panel-content {
    width: min(34rem, 100%);
    backdrop-filter: blur(2px);
  }

  .panel-number {
    display: inline-block;
    font-size: 0.84rem;
    letter-spacing: 0.28em;
    font-weight: 700;
    color: color-mix(in srgb, var(--accent), #ffffff 35%);
    margin-bottom: 0.8rem;
  }

  .panel-content h2 {
    margin: 0;
    text-transform: uppercase;
    line-height: 0.9;
    font-size: clamp(1.85rem, 6vw, 4.2rem);
    letter-spacing: 0.02em;
    color: rgba(246, 248, 255, 0.92);
  }

  .panel-subtitle {
    margin: 0.7rem 0 0;
    color: color-mix(in srgb, var(--accent), #ffffff 42%);
    font-size: clamp(0.98rem, 2.2vw, 1.2rem);
    font-weight: 600;
  }

  .panel-description {
    margin: 0.95rem 0 0;
    color: rgba(210, 210, 210, 0.78);
    line-height: 1.6;
    max-width: 50ch;
  }

  .panel-tone {
    margin: 0.85rem 0 0;
    color: rgba(175, 175, 175, 0.65);
    font-size: 0.94rem;
    letter-spacing: 0.02em;
  }

  @media (max-width: 900px) {
    .about-hero {
      min-height: 76svh;
      padding-top: 7.4rem;
    }

    .story-panel,
    .panel-content-wrap {
      min-height: 74svh;
    }

    .panel-shade {
      background: linear-gradient(
        180deg,
        rgba(3, 5, 9, 0.9),
        rgba(3, 5, 9, 0.42) 40%,
        color-mix(in srgb, var(--accent), transparent 84%)
      );
    }

    .is-right .panel-content-wrap {
      justify-items: start;
    }

    .panel-content {
      max-width: 30rem;
    }
  }

  @media (max-width: 600px) {
    .about-hero {
      min-height: 68svh;
      padding: 6.5rem 1rem 3rem;
    }

    .hero-copy {
      font-size: 0.95rem;
    }

    .cinematic-areas {
      gap: 0.8rem;
      padding: 0.8rem 0 3rem;
    }

    .story-panel,
    .panel-content-wrap {
      min-height: 68svh;
    }

    .panel-content-wrap {
      padding: 1.5rem 1rem;
    }

    .panel-content {
      width: 100%;
      max-width: 100%;
    }

    .panel-content h2 {
      font-size: clamp(1.5rem, 8vw, 2.5rem);
    }

    .panel-subtitle {
      font-size: 0.95rem;
    }

    .panel-description {
      font-size: 0.9rem;
    }

    .panel-tone {
      font-size: 0.85rem;
    }

    .panel-number {
      font-size: 0.75rem;
    }
  }
</style>
