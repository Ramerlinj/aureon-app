---

---

<section
  class="relative overflow-hidden bg-[#02050b] py-20 sm:py-24"
  data-home-section
>
  <div
    class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_15%_45%,rgba(255,255,255,0.05),transparent_45%)]"
  >
  </div>

  <div
    class="relative mx-auto grid w-full max-w-6xl gap-12 px-6 sm:px-10 lg:grid-cols-[1fr_auto] lg:items-center"
  >
    <div class="max-w-xl" data-reveal-group>
      <h2
        class="text-4xl font-extrabold uppercase tracking-tight text-white sm:text-5xl"
        data-reveal
      >
        IMPULSANDO SOLUCIONES
      </h2>
      <p class="mt-8 text-2xl leading-relaxed text-zinc-400" data-reveal>
        Transformamos ideas en soluciones digitales innovadoras que potencian tu
        negocio. Con tecnología de vanguardia y equipo experto, creamos
        experiencias que generan impacto real en tu audiencia y resultados
        medibles para tu empresa.
      </p>
    </div>

    <div
      class="flex flex-col items-center gap-6 sm:flex-row sm:items-end sm:gap-6 lg:justify-end"
      data-reveal-group
    >
      <article
        class="group relative h-52 w-full max-w-[12rem] overflow-hidden rounded-2xl border border-zinc-700/70 bg-zinc-950/70 text-xl font-medium tracking-wide text-zinc-300 shadow-[0_0_0_1px_rgba(255,255,255,0.03)] sm:h-72 sm:w-52 sm:max-w-none"
        data-reveal
      >
        <img
          src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&w=900&q=80"
          alt="Equipo analizando datos de negocio"
          class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
          loading="lazy"
          decoding="async"
        />
        <div
          class="absolute inset-0 bg-linear-to-t from-black/70 via-black/20 to-transparent"
        >
        </div>
        <p
          class="absolute bottom-3 left-3 text-sm font-semibold uppercase tracking-[0.12em] text-zinc-100"
        >
        </p>
      </article>
      <article
        class="group relative mb-10 h-72 w-full max-w-[14rem] overflow-hidden rounded-2xl border border-zinc-700/70 bg-zinc-950/70 text-xl font-medium tracking-wide text-zinc-300 shadow-[0_0_0_1px_rgba(255,255,255,0.03)] sm:h-80 sm:w-56 sm:max-w-none"
        data-reveal
      >
        <img
          src="https://images.unsplash.com/photo-1498050108023-c5249f4df085?auto=format&fit=crop&w=900&q=80"
          alt="Mesa de trabajo de multimedia y contenido"
          class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
          loading="lazy"
          decoding="async"
        />
        <div
          class="absolute inset-0 bg-linear-to-t from-black/70 via-black/20 to-transparent"
        >
        </div>
        <p
          class="absolute bottom-3 left-3 text-sm font-semibold uppercase tracking-[0.12em] text-zinc-100"
        >
        </p>
      </article>
    </div>
  </div>
</section>
