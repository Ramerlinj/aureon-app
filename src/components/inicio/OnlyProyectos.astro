---

---

<section
  class="relative overflow-hidden bg-[#02050b] py-20 sm:py-24"
  aria-label="Proyectos destacados"
  data-home-section
>
  <div
    class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_50%_0%,rgba(255,255,255,0.04),transparent_46%)]"
  >
  </div>

  <div class="relative mx-auto w-full max-w-6xl px-6 sm:px-10">
    <header class="mx-auto max-w-4xl text-center" data-reveal-group>
      <h2
        class="text-4xl font-extrabold uppercase tracking-tight text-white sm:text-5xl"
        data-reveal
      >
        PROYECTOS DESTACADOS
      </h2>
      <p
        class="mt-5 text-lg leading-relaxed text-zinc-400 sm:text-xl"
        data-reveal
      >
        Algunos de los proyectos que reflejan nuestra forma de trabajar, nuestro
        enfoque en la calidad y el compromiso con cada solución desarrollada.
      </p>
    </header>

    <div
      class="mt-12 grid gap-4 md:mt-14 md:grid-cols-2 md:gap-6"
      data-reveal-group
    >
      <div class="grid gap-4 md:gap-6">
        <article
          class="group relative h-72 overflow-hidden rounded-none border border-zinc-800/85 bg-zinc-950/55 transition duration-300 hover:border-zinc-700 sm:h-[25rem]"
          data-reveal
        >
          <img
            src="/Proyecto-florcast.png"
            alt="Proyecto Florcast - Aplicacion de flores y decoracion"
            class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
            loading="lazy"
            decoding="async"
          />
          <div
            class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"
          >
          </div>
          <p
            class="absolute bottom-3 left-3 text-sm font-semibold uppercase tracking-[0.15em] text-zinc-100"
          >
            Florcast
          </p>
        </article>
        <article
          class="group relative h-56 overflow-hidden rounded-none border border-zinc-800/85 bg-zinc-950/55 transition duration-300 hover:border-zinc-700 sm:h-[16rem]"
          data-reveal
        >
          <img
            src="/proyecto-juego.png"
            alt="Proyecto de desarrollo de videojuego interactivo"
            class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
            loading="lazy"
            decoding="async"
          />
          <div
            class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"
          >
          </div>
          <p
            class="absolute bottom-3 left-3 text-sm font-semibold uppercase tracking-[0.15em] text-zinc-100"
          >
            Videojuego
          </p>
        </article>
      </div>

      <div class="grid gap-4 md:gap-6">
        <article
          class="group relative h-56 overflow-hidden rounded-none border border-zinc-800/85 bg-zinc-950/55 transition duration-300 hover:border-zinc-700 sm:h-[16rem]"
          data-reveal
        >
          <img
            src="/proyecto-restaurant.png"
            alt="Proyecto de plataforma digital para restaurante"
            class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
            loading="lazy"
            decoding="async"
          />
          <div
            class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"
          >
          </div>
          <p
            class="absolute bottom-3 left-3 text-sm font-semibold uppercase tracking-[0.15em] text-zinc-100"
          >
            Restaurante
          </p>
        </article>
        <article
          class="group relative h-72 overflow-hidden rounded-none border border-zinc-800/85 bg-zinc-950/55 transition duration-300 hover:border-zinc-700 sm:h-[25rem]"
          data-reveal
        >
          <img
            src="/proyecto-biblioteca.png"
            alt="Proyecto de sistema de gestion para biblioteca digital"
            class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
            loading="lazy"
            decoding="async"
          />
          <div
            class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"
          >
          </div>
          <p
            class="absolute bottom-3 left-3 text-sm font-semibold uppercase tracking-[0.15em] text-zinc-100"
          >
            Biblioteca
          </p>
        </article>
      </div>
    </div>
  </div>
</section>
