---
const siteLinks = [
  { label: "Soluciones", href: "/#soluciones" },
  { label: "Proceso", href: "/#proceso" },
  { label: "Proyectos", href: "/#proyectos" },
  { label: "Testimonios", href: "/#testimonios" },
];

const socialLinks = [
  { label: "Discord", href: "#" },
  { label: "GitHub", href: "#" },
  { label: "X/Twitter", href: "#" },
  { label: "YouTube", href: "#" },
];

const ourSitesLinks = [
  { label: "Aureon B", href: "#" },
  { label: "Aureon A", href: "#" },
  { label: "Aureon C", href: "#" },
  { label: "Aureon D", href: "#" },
];
---

<footer
  class="footer-root relative overflow-hidden border-t border-white/8 bg-[#030406] pt-20 sm:pt-24"
  aria-label="Pie de pagina"
>
  <div
    class="pointer-events-none absolute left-0 right-0 top-0 h-px bg-linear-to-r from-transparent via-white/20 to-transparent"
  >
  </div>

  <div class="footer-word" aria-hidden="true">
    <span>AUREON</span>
  </div>

  <div class="relative mx-auto w-full max-w-6xl px-6 pb-10 sm:px-10 sm:pb-12">
    <nav
      class="grid gap-10 sm:grid-cols-2 lg:grid-cols-[1.2fr_1fr_1fr]"
      aria-label="Enlaces del pie de pagina"
    >
      <div>
        <h3
          class="text-sm font-semibold uppercase tracking-[0.12em] text-zinc-100"
        >
          SITE
        </h3>
        <ul class="mt-4 space-y-2.5">
          {
            siteLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-lg text-zinc-400 transition duration-200 hover:text-zinc-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan-300/70"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h3
          class="text-sm font-semibold uppercase tracking-[0.12em] text-zinc-100"
        >
          SOCIAL
        </h3>
        <ul class="mt-4 space-y-2.5">
          {
            socialLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-lg text-zinc-400 transition duration-200 hover:text-zinc-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan-300/70"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h3
          class="text-sm font-semibold uppercase tracking-[0.12em] text-zinc-100"
        >
          SITIOS NUESTROS
        </h3>
        <ul class="mt-4 space-y-2.5">
          {
            ourSitesLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-lg text-zinc-400 transition duration-200 hover:text-zinc-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan-300/70"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </nav>

    <div
      class="mt-16 flex flex-wrap items-center justify-between gap-4 border-t border-white/10 pt-8"
    >
      <p class="text-base text-zinc-400">
        Latest version:
        <span class="rounded bg-white/6 px-2 py-1 font-semibold text-zinc-100"
          >1.0.0</span
        >
      </p>

      <div
        class="flex flex-wrap items-center gap-3 rounded-2xl border border-white/10 bg-white/5 p-2"
      >
        <span
          class="rounded-xl border border-white/15 bg-white/12 px-3 py-2 text-base font-semibold text-white shadow-[inset_0_1px_0_rgba(255,255,255,0.2)]"
          >Aureon</span
        >
        <a
          href="#"
          class="rounded-xl border border-emerald-300/25 bg-emerald-300/10 px-3 py-2 text-base font-medium text-emerald-300 transition duration-200 hover:bg-emerald-300/20"
        >
          Preordena uno de nuestros productos
        </a>
      </div>
    </div>
  </div>

  <a
    href="/#inicio"
    aria-label="Volver arriba"
    id="back-to-top"
    class="back-to-top absolute bottom-6 right-6 grid h-12 w-12 place-items-center rounded-full border border-white/20 bg-white/8 text-xl font-semibold text-zinc-100 transition duration-300 hover:bg-white/14 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan-300/70 sm:bottom-8 sm:right-8"
  >
    <span class="back-to-top-arrow" aria-hidden="true">↑</span>
  </a>
</footer>

<script is:inline>
  (() => {
    const trigger = document.getElementById("back-to-top");
    if (!trigger) return;

    trigger.addEventListener("click", (event) => {
      event.preventDefault();
      trigger.classList.remove("is-lifting");
      void trigger.offsetWidth;
      trigger.classList.add("is-lifting");

      window.scrollTo({
        top: 0,
        behavior: "smooth",
      });
    });
  })();
</script>

<style>
  .footer-root {
    isolation: isolate;
  }

  .footer-word {
    position: absolute;
    inset: 2.5rem 0 auto;
    display: grid;
    place-items: center;
    pointer-events: none;
    z-index: 0;
    opacity: 0.28;
  }

  .footer-word span {
    font-size: clamp(4.5rem, 20vw, 15rem);
    font-weight: 800;
    letter-spacing: 0.04em;
    line-height: 0.92;
    text-transform: uppercase;
    color: transparent;
    background-image:
      radial-gradient(circle, rgba(255, 255, 255, 0.16) 1px, transparent 1.7px),
      linear-gradient(
        90deg,
        rgba(120, 9, 26, 0.32) 0%,
        rgba(255, 255, 255, 0.08) 64%,
        rgba(255, 255, 255, 0.03) 100%
      );
    background-size:
      6px 6px,
      100% 100%;
    background-position: center;
    -webkit-background-clip: text;
    background-clip: text;
    filter: blur(0.2px);
    user-select: none;
  }

  .back-to-top {
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.18),
      0 10px 28px rgba(0, 0, 0, 0.35);
  }

  .back-to-top::before {
    content: "";
    position: absolute;
    inset: -2px;
    border-radius: inherit;
    border: 1px solid rgba(255, 255, 255, 0.1);
    opacity: 0;
    transform: scale(0.9);
    transition: 220ms ease;
  }

  .back-to-top:hover {
    transform: translateY(-3px);
  }

  .back-to-top:hover::before {
    opacity: 1;
    transform: scale(1);
  }

  .back-to-top-arrow {
    display: inline-block;
    transition: transform 260ms ease;
  }

  .back-to-top:hover .back-to-top-arrow {
    transform: translateY(-1px);
  }

  .back-to-top.is-lifting .back-to-top-arrow {
    animation: arrowLift 520ms cubic-bezier(0.2, 0.75, 0.22, 1);
  }

  @keyframes arrowLift {
    0% {
      transform: translateY(0);
      opacity: 1;
    }

    45% {
      transform: translateY(-12px);
      opacity: 0.1;
    }

    55% {
      transform: translateY(12px);
      opacity: 0.1;
    }

    100% {
      transform: translateY(0);
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .back-to-top,
    .back-to-top-arrow,
    .back-to-top::before {
      transition: none;
    }

    .back-to-top.is-lifting .back-to-top-arrow {
      animation: none;
    }
  }
</style>
