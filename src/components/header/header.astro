---
const links = [
  { label: "Soluciones", href: "/#soluciones" },
  { label: "Proceso", href: "/#proceso" },
  { label: "Proyectos", href: "/#proyectos" },
  { label: "Testimonios", href: "/#testimonios" },
];
import { ModeToggle } from "@/components/ModeToggle";
---

<header class="fixed left-0 top-0 z-50 w-full px-3 pt-3 sm:px-6 sm:pt-5">
  <nav
    class="mx-auto grid w-full max-w-3xl grid-cols-[auto_1fr_auto] items-center gap-3 overflow-hidden rounded-2xl border border-white/12 bg-[radial-gradient(120%_130%_at_0%_40%,rgba(132,160,255,0.12),transparent_42%),radial-gradient(120%_130%_at_100%_50%,rgba(0,190,255,0.08),transparent_44%),#090b10] px-3 py-2.5 shadow-[inset_0_1px_0_rgba(255,255,255,0.1),0_10px_30px_rgba(0,0,0,0.4)] backdrop-blur-md"
    aria-label="Navegacion principal"
  >
    <a
      href="/"
      class="inline-flex items-center gap-2.5 text-slate-100 no-underline"
    >
      <span
        class="grid h-6 w-6 place-items-center rounded-md border border-white/25 bg-white/6 text-xs font-bold tracking-[0.04em]"
      >
        A
      </span>
      <span
        class="hidden text-sm font-semibold tracking-[0.08em] text-zinc-100 sm:inline"
        >AUREON</span
      >
    </a>

    <ul
      class="mx-auto flex min-w-0 list-none items-center justify-center gap-1 overflow-x-auto px-0 [scrollbar-width:none] [&::-webkit-scrollbar]:hidden"
    >
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class="inline-flex whitespace-nowrap rounded-lg px-3 py-2 text-sm font-medium text-zinc-300/95 no-underline transition duration-200 hover:bg-white/8 hover:text-zinc-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan-300/70"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="flex items-center justify-end">
      <ModeToggle client:load />
    </div>
  </nav>
</header>
